# =============================================================================
# SEOPen — Environment Variables
# Copy this file to .env and fill in the values
#
# Single-container deployment: Web + API in one container
# Only ONE domain needed — no api.your-domain.com subdomain required
# =============================================================================

# ── App URL (used everywhere — only 1 domain needed) ─────────────────────────
# This is the public URL of your app, e.g. https://seopen.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Encryption (AES-256-GCM — used to store WordPress App Passwords) ─────────
# Generate: openssl rand -base64 32
# ⚠️  Do NOT change this after first deploy — stored passwords will be unreadable
ENCRYPTION_KEY=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SERP_API_KEY=

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Authorized redirect URI to add in Google Cloud Console:
#   https://your-domain.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
