# Database
DATABASE_URL=postgresql://seopen:seopen_secret@postgres:5432/seopen?schema=public
# For local development (non-Docker): DATABASE_URL=postgresql://seopen:seopen_secret@localhost:5432/seopen?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
# For local development (non-Docker): REDIS_HOST=localhost

# API
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Third-party APIs
ANTHROPIC_API_KEY=your-anthropic-api-key
SERP_API_KEY=your-serpapi-key

# OAuth (Optional - for local auth without OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_URL=http://localhost:3000
